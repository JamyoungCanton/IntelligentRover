
page {
  height: 100%;
}
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}
.nav-header {
  height: 88rpx;
  background-color: #0066CC;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  flex-shrink: 0;
}
.nav-title {
  color: #ffffff;
  font-size: 16px;
  font-weight: 500;
}
.history-icon {
  width: 48rpx;
  height: 48rpx;
}
.content-container {
  flex: 1;
  overflow: auto;
}
.search-card {
  margin: 32rpx;
  padding: 32rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}
.location-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}
.location-item {
  flex: 1;
}
.exchange-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.align-right {
  text-align: right;
}
.label {
  font-size: 14px;
  color: #333333;
  font-weight: 500;
  margin-bottom: 8rpx;
  display: block;
}
.value {
  font-size: 14px;
  color: #0066CC;
}
.date-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 32rpx;
}
.date-item {
  flex: 1;
}
.search-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #0066CC;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 14px;
}
.filter-bar {
  margin: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.filter-left {
  display: flex;
  align-items: center;
}
.filter-text {
  font-size: 14px;
  color: #666666;
  margin-left: 8rpx;
}
.filter-right {
  display: flex;
  align-items: center;
}
.sort-item {
  display: flex;
  align-items: center;
  margin-left: 32rpx;
}
.sort-text {
  font-size: 14px;
  color: #666666;
  margin-right: 8rpx;
}
.ticket-list {
  margin: 0 32rpx;
}
.ticket-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}
.time-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.time {
  font-size: 16px;
  font-weight: 500;
  color: #333333;
}
.duration {
  font-size: 14px;
  color: #999999;
}
.ship-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.ship-name {
  font-size: 14px;
  color: #666666;
}
.price {
  font-size: 14px;
  color: #0066CC;
  font-weight: 500;
}
.action-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.remain {
  font-size: 14px;
  color: #999999;
}
.book-btn {
  padding: 0 32rpx;
  width: 230rpx;
  margin-right: 5rpx;
  height: 64rpx;
  line-height: 64rpx;
  background: #0066CC;
  color: #ffffff;
  font-size: 14px;
  border-radius: 8rpx;
}


