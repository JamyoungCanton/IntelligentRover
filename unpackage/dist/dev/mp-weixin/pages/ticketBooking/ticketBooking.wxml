<view class="container"><view class="nav-header"><text class="nav-title">船票预定</text><uni-icons wx:if="{{a}}" class="history-icon" u-i="a2474e52-0" bind:__l="__l" u-p="{{a}}"/></view><scroll-view class="content-container" scroll-y><view class="search-card"><view class="location-row"><view class="location-item"><text class="label">出发地</text><text class="value">万山港</text></view><view class="exchange-btn"><uni-icons wx:if="{{b}}" u-i="a2474e52-1" bind:__l="__l" u-p="{{b}}"/></view><view class="location-item align-right"><text class="label">目的地</text><text class="value">东澳岛</text></view></view><view class="date-row"><view class="date-item"><text class="label">出发日期</text><text class="value">2024-01-20</text></view><view class="date-item align-right"><text class="label">乘车人数</text><text class="value">2 人</text></view></view><button class="search-btn" type="primary">查询船票</button></view><view class="filter-bar"><view class="filter-left"><uni-icons wx:if="{{c}}" u-i="a2474e52-2" bind:__l="__l" u-p="{{c}}"/><text class="filter-text">筛选</text></view><view class="filter-right"><view class="sort-item"><text class="sort-text">时间</text><uni-icons wx:if="{{d}}" u-i="a2474e52-3" bind:__l="__l" u-p="{{d}}"/></view><view class="sort-item"><text class="sort-text">价格</text><uni-icons wx:if="{{e}}" u-i="a2474e52-4" bind:__l="__l" u-p="{{e}}"/></view></view></view><view class="ticket-list"><view wx:for="{{f}}" wx:for-item="item" wx:key="f" class="ticket-card"><view class="time-row"><text class="time">{{item.a}}</text><text class="duration">{{item.b}}</text></view><view class="ship-row"><text class="ship-name">{{item.c}}</text><text class="price">{{item.d}}</text></view><view class="action-row"><text class="remain">剩余 {{item.e}} 张</text><button class="book-btn primary" type="button" size="mini">预订</button></view></view></view></scroll-view></view>