
page {
  height: 100%;
  background-color: #F8F9FA;
}
.page {
  display: flex;
  flex-direction: column;
  height: 100%;
}
.nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 88rpx;
  background-color: #1E88E5;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  z-index: 100;
}
.nav-title {
  font-size: 16px;
  color: #ffffff;
  font-weight: 500;
}
.nav-btn {
  font-size: 14px;
  color: #ffffff;
}
.main {
  flex: 1;
  padding: 120rpx 32rpx 0;
  overflow: auto;
}
.points-card {
  background-color: #1E88E5;
  border-radius: 16rpx;
  padding: 48rpx;
  margin-bottom: 48rpx;
}
.points-info {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}
.points-label {
  display: block;
  font-size: 14px;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
}
.points-value {
  display: block;
  font-size: 24px;
  color: #ffffff;
  font-weight: 600;
}
.points-actions {
  display: flex;
  gap: 32rpx;
}
.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  opacity: 0.9;
}
.action-btn text {
  font-size: 14px;
  color: #ffffff;
  margin-top: 8rpx;
}
.action-buttons {
  display: flex;
  gap: 32rpx;
  margin-bottom: 48rpx;
}
.upload-btn, .exchange-btn {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
}
.upload-btn {
  background-color: #1E88E5;
  color: #ffffff;
}
.exchange-btn {
  background-color: #ffffff;
  color: #1E88E5;
  border: 2rpx solid #1E88E5;
}
.upload-btn text, .exchange-btn text {
  margin-left: 16rpx;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}
.section-title {
  font-size: 16px;
  font-weight: 500;
  color: #333333;
}
.view-all {
  font-size: 14px;
  color: #808080;
}
.scroll-container {
  overflow: auto;
}
.exchange-items {
  display: flex;
  gap: 32rpx;
}
.exchange-item {
  flex-shrink: 0;
  width: 280rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
}
.exchange-item image {
  width: 240rpx;
  height: 240rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}
.item-title {
  display: block;
  font-size: 14px;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8rpx;
}
.item-points {
  font-size: 12px;
  color: #808080;
}
.receipt-records {
  margin-top: 48rpx;
}
.record-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}
.record-item {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  padding: 32rpx;
  border-radius: 16rpx;
}
.receipt-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  margin-right: 32rpx;
}
.record-info {
  flex: 1;
}
.record-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}
.shop-name {
  font-size: 14px;
  font-weight: 500;
  color: #333333;
}
.points-earned {
  font-size: 14px;
  color: #1E88E5;
}
.amount, .time {
  display: block;
  font-size: 14px;
  color: #808080;
  margin-bottom: 8rpx;
}
.status {
  font-size: 12px;
  color: #4CAF50;
  margin-left: 32rpx;
}


