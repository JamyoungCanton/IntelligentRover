<view class="itinerary-confirmation"><view class="page-title">行程确认</view><view class="section"><view class="section-header"><image src="{{a}}" mode="aspectFit"></image><text>行程安排</text></view><view wx:for="{{b}}" wx:for-item="scheduleItem" wx:key="c" class="schedule-item"><text class="time">{{scheduleItem.a}}</text><text class="description">{{scheduleItem.b}}</text></view></view><view class="section"><view class="section-header"><image src="{{c}}" mode="aspectFit"></image><text>费用明细</text></view><view wx:for="{{d}}" wx:for-item="costItem" wx:key="c" class="cost-item"><text class="cost-name">{{costItem.a}}</text><text style="color:black">{{costItem.b}}</text></view><view class="cost-summary"><view class="summary-item"><text>原价</text><text>{{e}}</text></view><view class="summary-item"><text>优惠金额</text><text style="color:black">{{f}}</text></view><view class="summary-item total"><text>实付金额</text><text style="color:cornflowerblue;border:30px">{{g}}</text></view></view></view><view class="section"><view class="section-header"><image src="{{h}}" mode="aspectFit"></image><text>游客信息</text></view><input class="user-input" placeholder="请输入手机号码" value="{{i}}" bindinput="{{j}}"/></view><view class="section"><view class="section-header"><image src="{{k}}" mode="aspectFit"></image><text>备注信息</text></view><block wx:if="{{r0}}"><textarea class="notes-input" placeholder="请输入特殊需求或注意事项" value="{{l}}" bindinput="{{m}}"/></block></view><view class="section"><view class="section-header"><image src="{{n}}" mode="aspectFit"></image><text>支付方式</text></view><view class="payment-method" bindtap="{{r}}"><view class="payment-content"><image src="{{o}}" mode="aspectFit"></image><text>微信支付</text></view><image wx:if="{{p}}" src="{{q}}" mode="aspectFit"></image></view><view class="payment-method" bindtap="{{w}}"><view class="payment-content"><image src="{{s}}" mode="aspectFit"></image><text>支付宝</text></view><image wx:if="{{t}}" src="{{v}}" mode="aspectFit"></image></view></view><button class="confi