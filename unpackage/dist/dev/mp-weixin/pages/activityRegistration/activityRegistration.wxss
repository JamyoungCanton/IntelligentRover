
.container.data-v-600b90d9 {
  background-color: #f7f7f7;
  padding: 0 20px;
  padding-top: var(--f81af104);
}
.header.data-v-600b90d9 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 0;
  background-color: #007AFF;
}
.title.data-v-600b90d9 {
  font-size: 20px;
  font-weight: bold;
  color: white;
  text-align: center;
  flex: 1;
}
.back-btn.data-v-600b90d9 {
  margin-right: auto;
}
.registration-image.data-v-600b90d9 {
  width: calc(100% - 40px); /* 使图片宽度比顶部蓝色框窄一些 */
  height: 200px;
  object-fit: cover;
  border-radius: 10px;
  margin: 0 auto; /* 居中显示 */
  display: block;
}
.registration-info.data-v-600b90d9 {
  background-color: #fff;
  padding: 20px;
  margin-top: 10px;
}
.activity-name.data-v-600b90d9 {
  font-size: 20px;
  font-weight: bold;
  margin-bottom: 10px;
}
.info-item.data-v-600b90d9 {
  display: flex;
  align-items: center;
  margin-bottom: 10px;
}
.info-text.data-v-600b90d9 {
  margin-left: 10px;
  font-size: 14px;
  color: #666;
}
.price.data-v-600b90d9 {
  font-size: 24px;
  color: #007AFF;
  font-weight: bold;
}
.price-unit.data-v-600b90d9 {
  font-size: 14px;
  color: #666;
  margin-left: 5px;
}
.section-title.data-v-600b90d9 {
  font-size: 18px;
  font-weight: bold;
  margin: 20px 0 10px;
  padding-left: 10px;
  border-left: 4px solid #007AFF;
}
.form-item.data-v-600b90d9 {
  background-color: #fff;
  padding: 15px;
  margin-bottom: 10px;
  border-radius: 8px;
}
.label.data-v-600b90d9 {
  font-size: 16px;
  margin-bottom: 8px;
}
.input.data-v-600b90d9 {
  width: 100%;
  border: 1px solid #ddd;
  border-radius: 8px;
  padding: 10px;
  font-size: 14px;
}
.counter.data-v-600b90d9 {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.counter-btn.data-v-600b90d9 {
  background-color: #007AFF;
  color: white;
  border: none;
  width: 30px;
  height: 30px;
  border-radius: 5px;
  display: flex;
  justify-content: center;
  align-items: center;
  cursor: pointer;
}
.counter-btn.minus.data-v-600b90d9 {
  margin-left: 0;
}
.counter-btn.disabled.data-v-600b90d9 {
  background-color: #ccc;
  cursor: not-allowed;
}
.counter-value.data-v-600b90d9 {
  font-size: 16px;
  text-align: center;
  flex: 1;
}
.cost-details.data-v-600b90d9 {
  background-color: #fff;
  padding: 20px;
  margin-top: 10px;
}
.cost-item.data-v-600b90d9 {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10px;
}
.cost-name.data-v-600b90d9 {
  font-size: 14px;
  color: #666;
}
.cost-value.data-v-600b90d9 {
  font-size: 14px;
  font-weight: bold;
}
.agreement.data-v-600b90d9 {
  display: flex;
  align-items: center;
  margin: 20px 0;
}
.agreement-text.data-v-600b90d9 {
  font-size: 12px;
  color: #666;
}
.submit-btn.data-v-600b90d9 {
  width: 100%;
  background-color: #007AFF;
  color: white;
  border: none;
  border-radius: 8px;
  padding: 15px;
  font-size: 16px;
  margin-top: 10px;
}
