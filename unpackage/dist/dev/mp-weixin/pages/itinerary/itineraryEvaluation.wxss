
.container.data-v-e4b8447a {
  padding: 0 20px;
  background-color: #f7f7f7;
  min-height: 100vh;
}
.header.data-v-e4b8447a {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px 0;
}
.title.data-v-e4b8447a {
  font-size: 20px;
  font-weight: bold;
}
.evaluation-section.data-v-e4b8447a {
  background-color: #fff;
  border-radius: 10px;
  padding: 20px;
  margin-bottom: 20px;
}
.section-title.data-v-e4b8447a {
  font-size: 18px;
  font-weight: bold;
}

/* 整体满意度样式 */
.satisfaction-options-container.data-v-e4b8447a {
  display: flex;
  justify-content: space-between;
  margin: 0 -10px; /* 调整左右外边距，使选项居中并有间隔 */
}
.option-item.data-v-e4b8447a {
  flex: 1;
  margin: 0 10px; /* 左右间隔 */
  margin-top: 10px;
}
.option-wrapper.data-v-e4b8447a {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 15px;
  border: 1px solid #f0f0f0;
  border-radius: 8px;
  background-color: #fff;
  cursor: pointer;
}
.option-icon image.data-v-e4b8447a {
  width: 20px; /* 调整图片大小 */
  height: 20px; /* 调整图片大小 */
  margin-bottom: 8px;
}
.option-label.data-v-e4b8447a {
  font-size: 10px; /* 调整字体大小 */
  white-space: nowrap; /* 防止换行 */
}

/* 行程评分样式 */
.rating-items-container.data-v-e4b8447a {
  margin-top: 10px;
}
.rating-item.data-v-e4b8447a {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15px 0;
  border-bottom: 1px solid #f0f0f0;
  border: 1px solid #f0f0f0;
  border-radius: 8px;
  margin-bottom: 10px;
}
.rating-label.data-v-e4b8447a {
  font-size: 16px;
  padding: 0 10px;
}
.star-rating.data-v-e4b8447a {
  display: flex;
  align-items: center;
  margin-left: auto; /* 调整星星和右侧框的间隔 */
  margin-right: 10px; /* 与右侧线留出10px的距离 */
}
.star-item.data-v-e4b8447a {
  margin-left: 5px;
  width: 15px; /* 调整星星大小 */
  height: 15px; /* 调整星星大小 */
}
.star-item image.data-v-e4b8447a {
  width: 100%;
  height: 100%;
}

/* 详细反馈样式 */
.feedback-container.data-v-e4b8447a {
  position: relative;
  top: 10px;
}
.feedback-textarea.data-v-e4b8447a {
  width: 100%;
  height: 120px;
  border: 1px solid #ddd;
  border-radius: 10px;
  padding: 10px;
  font-size: 14px;
  margin-bottom: 10px;
}
.voice-input.data-v-e4b8447a {
  position: absolute;
  right: 10px;
  bottom: 10px;
}
.voice-icon.data-v-e4b8447a {
  width: 30px;
  height: 30px;
  cursor: pointer;
}

/* 图片上传样式 */
.photo-upload.data-v-e4b8447a {
  margin-top: 20px;
  display: flex;
  flex-direction: column;
  align-items: flex-start; /* 调整为左对齐 */
}
.upload-area.data-v-e4b8447a {
  display: flex;
  flex-direction: column;
  align-items: flex-start; /* 调整为左对齐 */
  margin-bottom: 10px;
}
.upload-btn.data-v-e4b8447a {
  margin-bottom: 10px;
  cursor: pointer;
}
.upload-btn image.data-v-e4b8447a {
  width: 80px; /* 调整照相机图标大小 */
  height: 80px; /* 调整照相机图标大小 */
}
.photo-limit.data-v-e4b8447a {
  font-size: 12px;
  color: #999;
  text-align: left; /* 调整为左对齐 */
}
.photo-preview-container.data-v-e4b8447a {
  display: flex;
  flex-wrap: wrap;
  margin-top: 10px;
}
.photo-preview.data-v-e4b8447a {
  position: relative;
  margin: 0 10px 10px 0;
  width: 60px;
  height: 60px;
  border-radius: 5px;
  overflow: hidden;
}
.photo-preview image.data-v-e4b8447a {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.delete-photo.data-v-e4b8447a {
  position: absolute;
  top: 0;
  right: 0;
  background-color: rgba(255, 0, 0, 0.7);
  width: 20px;
  height: 20px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.delete-photo image.data-v-e4b8447a {
  width: 12px;
  height: 12px;
}
.submit-button.data-v-e4b8447a {
  margin-top: 20px;
}
.submit-btn.data-v-e4b8447a {
  width: 100%;
  height: 48px;
  background-color: #1989fa;
  color: #fff;
  border: none;
  border-radius: 24px;
  font-size: 18px;
}
